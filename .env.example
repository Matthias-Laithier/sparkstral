MISTRAL_API_KEY=your_mistral_api_key_here
SERPER_API_KEY=your_serper_api_key_here
# Backend Postgres (use this URL in Docker; for local backend without Docker, adjust host/port)
DATABASE_URL=postgresql+psycopg://sparkstral:sparkstral@postgres:5432/sparkstral
# Workflow worker: HTTP base URL of the API (web search cache). Docker Compose sets this; optional override.
BACKEND_BASE_URL=http://backend:8000
DEPLOYMENT_NAME=sparkstral
WEB_SEARCH_MODEL=mistral-small-latest
WEB_SEARCH_MAX_ROUNDS=8
COMPANY_PROFILER_AGENT_MODEL=mistral-medium-latest
PAIN_POINT_PROFILER_AGENT_MODEL=mistral-medium-latest
GENAI_USE_CASES_MODEL=mistral-medium-latest
LLM_MAX_TOKENS=2048
LLM_TEMPERATURE=0
GENAI_USE_CASES_LLM_TEMPERATURE=1
