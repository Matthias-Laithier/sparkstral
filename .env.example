MISTRAL_API_KEY=your_mistral_api_key_here
SERPER_API_KEY=your_serper_api_key_here
TAVILY_API_KEY=your_tavily_api_key_here
DATABASE_URL=postgresql+psycopg://sparkstral:sparkstral@postgres:5432/sparkstral
BACKEND_BASE_URL=http://backend:8000
DEPLOYMENT_NAME=sparkstral
WEB_SEARCH_PROVIDER=serper
WEB_SEARCH_MODEL=mistral-medium-latest
WEB_SEARCH_MAX_ROUNDS=8
COMPANY_RESOLVER_AGENT_MODEL=mistral-medium-latest
PAIN_POINT_PROFILER_AGENT_MODEL=mistral-medium-latest
GENAI_USE_CASES_MODEL=mistral-medium-latest
DEDUPLICATOR_AGENT_MODEL=mistral-small-latest
USE_CASE_GRADER_AGENT_MODEL=mistral-medium-latest
MARKDOWN_REPORTER_AGENT_MODEL=mistral-large-latest
LLM_MAX_TOKENS=8096
LLM_TEMPERATURE=0
GENAI_USE_CASES_LLM_TEMPERATURE=0.7
