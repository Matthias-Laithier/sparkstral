# SERPER_API_KEY=your_serper_api_key_here
# TAVILY_API_KEY=your_tavily_api_key_here
DEPLOYMENT_NAME=sparkstral
WEB_SEARCH_PROVIDER=mistralai
WEB_SEARCH_MODEL=mistral-small-latest
WEB_SEARCH_MAX_ROUNDS=4
GENAI_USE_CASES_MODEL=mistral-large-latest
USE_CASE_GRADER_AGENT_MODEL=mistral-medium-latest
MARKDOWN_REPORTER_AGENT_MODEL=mistral-medium-latest
LLM_MAX_TOKENS=8096
LLM_TEMPERATURE=0
GENAI_USE_CASES_LLM_TEMPERATURE=0.7
FACT_CHECK_MODEL=mistral-medium-latest
